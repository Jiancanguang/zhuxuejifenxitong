.page-header {
  padding: 20rpx 0 32rpx;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.page-subtitle {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}

.badge-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.badge-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.badge-medal {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.badge-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #334155;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.badge-date {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}
