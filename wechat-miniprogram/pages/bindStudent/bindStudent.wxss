.bind-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 60rpx 40rpx;
  margin-top: 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.bind-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.bind-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.bind-desc {
  font-size: 26rpx;
  color: #94a3b8;
  margin-bottom: 40rpx;
}

.input-wrapper {
  width: 100%;
  margin-bottom: 16rpx;
}

.code-input {
  width: 100%;
  height: 96rpx;
  border: 3rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 16rpx;
  text-align: center;
  color: #6366f1;
  background: #f8fafc;
  box-sizing: border-box;
}

.code-input:focus {
  border-color: #6366f1;
}

.error-text {
  font-size: 24rpx;
  color: #ef4444;
  margin-bottom: 16rpx;
  text-align: center;
}

.submit-btn {
  width: 100% !important;
  margin-top: 20rpx;
}

.tips {
  margin-top: 40rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 20rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 16rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 2;
}
