.login-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 48rpx 36rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.login-icon {
  font-size: 80rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  text-align: center;
  margin-bottom: 8rpx;
}

.login-desc {
  font-size: 26rpx;
  color: #94a3b8;
  text-align: center;
  margin-bottom: 36rpx;
}

.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #1e293b;
  background: #f8fafc;
  box-sizing: border-box;
}

.password-wrapper {
  position: relative;
}

.password-input {
  padding-right: 120rpx !important;
}

.password-toggle {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: #6366f1;
  font-weight: 500;
}

.search-btn {
  margin-top: 16rpx;
  width: 100% !important;
}

.login-btn {
  margin-top: 12rpx;
  width: 100% !important;
}

.error-text {
  font-size: 24rpx;
  color: #ef4444;
  margin-bottom: 16rpx;
  text-align: center;
}

/* 班级列表 */
.class-list {
  margin-top: 24rpx;
}

.class-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.class-item:active {
  background: #eef2ff;
}

.class-item-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.class-item-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #334155;
}

.class-item-arrow {
  font-size: 28rpx;
  color: #94a3b8;
}

.no-result {
  text-align: center;
  padding: 40rpx;
  color: #94a3b8;
  font-size: 26rpx;
}

/* 返回 */
.back-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.back-arrow {
  font-size: 28rpx;
  color: #6366f1;
  font-weight: 700;
}

.back-text {
  font-size: 26rpx;
  color: #6366f1;
}

/* 已选班级 */
.selected-class {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #eef2ff;
  border-radius: 16rpx;
}

.selected-class-icon {
  font-size: 32rpx;
}

.selected-class-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #6366f1;
}

/* 提示 */
.tips {
  margin-top: 32rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 20rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 16rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 2;
}
