.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
}

.hero-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 800;
  color: #1e293b;
  letter-spacing: 4rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  color: #6366f1;
  font-weight: 600;
  margin-top: 8rpx;
  letter-spacing: 8rpx;
  padding: 8rpx 24rpx;
  background: #eef2ff;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.hero-desc {
  font-size: 26rpx;
  color: #94a3b8;
  text-align: center;
  margin-top: 12rpx;
}

.action-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 40rpx 40rpx;
}

.bind-btn {
  width: 80% !important;
  font-size: 32rpx !important;
  padding: 28rpx 0 !important;
  border-radius: 20rpx !important;
}

.hint {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 20rpx;
}

.features {
  padding: 20rpx 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.feature-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.feature-text {
  flex: 1;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #334155;
}

.feature-desc {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}
