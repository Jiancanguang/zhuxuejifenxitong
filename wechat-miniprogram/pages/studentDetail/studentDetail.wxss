page {
  background: linear-gradient(180deg, #eef2ff 0%, #f8fafc 30%);
}

/* 学生卡片 */
.student-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.student-header {
  display: flex;
  align-items: center;
}

.student-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #eef2ff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-emoji {
  font-size: 40rpx;
}

.avatar-img {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
}

.student-info {
  flex: 1;
}

.student-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.class-name {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.unbind-btn {
  padding: 12rpx 24rpx;
  background: #fef2f2;
  border-radius: 12rpx;
}

.unbind-text {
  font-size: 22rpx;
  color: #ef4444;
}

/* 宠物卡片 */
.pet-card {
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  color: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(99, 102, 241, 0.3);
}

.pet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.pet-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pet-emoji {
  font-size: 40rpx;
}

.pet-img {
  width: 120rpx;
  height: 120rpx;
}

.pet-nickname {
  font-size: 32rpx;
  font-weight: 700;
}

.pet-stage-badge {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* 积分展示 */
.food-display {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  margin-bottom: 20rpx;
}

.food-count {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.food-number {
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.2;
}

.food-label {
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}

.food-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 进度条 */
.progress-section {
  margin-top: 8rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-label {
  font-size: 22rpx;
  opacity: 0.8;
}

.progress-value {
  font-size: 22rpx;
  font-weight: 600;
}

.progress-bar-bg {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: #ffffff;
  border-radius: 6rpx;
  transition: width 0.5s ease;
  min-width: 4rpx;
}

.progress-hint {
  font-size: 20rpx;
  opacity: 0.7;
  margin-top: 8rpx;
  text-align: right;
}

/* 排名卡片 */
.ranking-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.ranking-content {
  display: flex;
  align-items: center;
}

.ranking-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ranking-number {
  font-size: 44rpx;
  font-weight: 800;
  color: #6366f1;
  line-height: 1.2;
}

.ranking-label {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.ranking-divider {
  width: 2rpx;
  height: 48rpx;
  background: #e2e8f0;
}

/* Section */
.section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

.section-more {
  font-size: 24rpx;
  color: #6366f1;
}

/* 记录列表 */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-type {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #64748b;
}

.type-positive { background: #dcfce7; color: #16a34a; }
.type-negative { background: #fef2f2; color: #ef4444; }
.type-redeem { background: #fef3c7; color: #d97706; }
.type-graduate { background: #eef2ff; color: #6366f1; }

.record-name {
  font-size: 26rpx;
  color: #475569;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.record-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #475569;
}

.value-positive { color: #16a34a; }
.value-negative { color: #ef4444; }

.record-time {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.empty-records {
  text-align: center;
  padding: 40rpx;
  color: #94a3b8;
  font-size: 26rpx;
}

/* 徽章入口 */
.badge-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.badge-entry-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.badge-icon {
  font-size: 40rpx;
}

.badge-entry-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.badge-entry-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.badge-count {
  font-size: 26rpx;
  color: #6366f1;
  font-weight: 600;
}

.badge-arrow {
  font-size: 28rpx;
  color: #94a3b8;
}

/* 加载和错误状态 */
.loading-text {
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 20rpx;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #ef4444;
  margin-bottom: 32rpx;
  text-align: center;
}
